    {
      "name": "congregations",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"congregations\" (\"id\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, \"deleted_at\" TEXT NULL, \"hlc\" TEXT NULL, \"name\" TEXT NOT NULL, \"number\" TEXT NOT NULL DEFAULT '', \"color\" INTEGER NOT NULL, \"settings_json\" TEXT NOT NULL DEFAULT '{}', PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "people",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"people\" (\"id\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, \"deleted_at\" TEXT NULL, \"hlc\" TEXT NULL, \"congregation_id\" TEXT NOT NULL REFERENCES congregations (id), \"first_name\" TEXT NOT NULL DEFAULT '', \"last_name\" TEXT NOT NULL DEFAULT '', \"display_name\" TEXT NOT NULL, \"gender\" TEXT NOT NULL, \"privilege\" TEXT NOT NULL, \"qualifications\" TEXT NOT NULL DEFAULT '[]', \"origin_congregation\" TEXT NOT NULL DEFAULT '', \"active\" INTEGER NOT NULL DEFAULT 1 CHECK (\"active\" IN (0, 1)), \"notes\" TEXT NOT NULL DEFAULT '', \"last_used\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "person_absences",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"person_absences\" (\"id\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, \"deleted_at\" TEXT NULL, \"hlc\" TEXT NULL, \"person_id\" TEXT NOT NULL REFERENCES people (id), \"start_date\" TEXT NOT NULL, \"end_date\" TEXT NOT NULL, \"comment\" TEXT NOT NULL DEFAULT '', PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "projects",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"projects\" (\"id\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, \"deleted_at\" TEXT NULL, \"hlc\" TEXT NULL, \"congregation_id\" TEXT NOT NULL REFERENCES congregations (id), \"name\" TEXT NOT NULL, \"notes\" TEXT NOT NULL DEFAULT '', \"exported_at\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "programs",
      "sql": [
