// Google Sign-In URL scheme (macOS). Copy to
// macos/Runner/Configs/FirebaseSecrets.xcconfig (tool/bootstrap.sh does it)
// and paste the REVERSED_CLIENT_ID of YOUR Firebase iOS/macOS app
// (see docs/FIREBASE_SETUP.md). The real file is gitignored.
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.REPLACE_ME
